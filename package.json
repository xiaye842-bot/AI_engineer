{
  "name": "engineering-copilot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "A Pi-powered desktop engineering companion prototype",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/task-store.test.js",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "build": {
    "asar": true,
    "appId": "com.company.engineering-copilot",
    "productName": "工程伴随 AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir"
    }
  }
}
